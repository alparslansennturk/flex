rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUid() {
      return request.auth.uid;
    }

    // Gizli sistem sahibi — Firestore'a bakmadan tam yetki
    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'flexos.platform@gmail.com';
    }

    // Firestore dokümanındaki rollere bak (diğer kullanıcılar için)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(currentUid())).data;
    }

    function isAdmin() {
      return isSuperAdmin() ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['admin'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'admin');
    }

    function isInstructor() {
      return isAdmin() ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['instructor'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'instructor');
    }

    // ─── students ─────────────────────────────────────────────────────────────

    match /students/{studentId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow create: if isAdmin() || isInstructor();
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin();
    }

    // ─── groups ───────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() ||
        (isInstructor() && resource.data.instructorId == currentUid());
      allow create, delete: if isAdmin();
    }

    // ─── users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || currentUid() == userId);
      allow update: if isSignedIn() && (isAdmin() || currentUid() == userId);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── tasks ────────────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── templates ────────────────────────────────────────────────────────────

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── scores_backup ────────────────────────────────────────────────────────

    match /scores_backup/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin();
    }

    match /scores_backup_entries/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin();
    }
  }
}
