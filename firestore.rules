rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'surname', 'roles']) &&
             data.email is string &&
             data.name is string &&
             data.surname is string &&
             data.roles is list;
    }

    function currentUid() {
      return request.auth.uid;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'flexos.platform@gmail.com';
    }

    // users koleksiyonunda kaydı olmayan kullanıcılar için güvenli dönüş ({})
    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(currentUid()));
      return userDoc.exists ? userDoc.data : {};
    }

    // Admin: JWT token birincil, Firestore fallback
    // Sadece gerçek admin rolüne sahip kullanıcılar — instructor bu fonksiyonu geçemez
    function isAdmin() {
      return isSuperAdmin() ||
        (isSignedIn() && request.auth.token.role == 'admin') ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['admin'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'admin');
    }

    // Instructor: JWT token birincil, Firestore fallback
    // isAdmin() dahil — admin her şeyi yapabilir, instructor yalnızca kendi sınıflarını
    function isInstructor() {
      return isAdmin() ||
        (isSignedIn() && request.auth.token.role == 'instructor') ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['instructor'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'instructor');
    }

    // Belirli eğitmenlere verilen ek izinler (permissionOverrides map'i üzerinden)
    function hasPermissionOverride(perm) {
      return isSignedIn() && getUserData().get('permissionOverrides', {}).get(perm, false) == true;
    }

    // Öğrenci auth UID ile studentId (doc ID) eşleşmeyebilir — üç yol ile kontrol et
    function isStudentOwner(studentDocId) {
      let studentDoc = get(/databases/$(database)/documents/students/$(studentDocId));
      let userDoc    = get(/databases/$(database)/documents/users/$(currentUid()));
      return studentDocId == currentUid() ||
             (studentDoc.exists && studentDoc.data.authUid == currentUid()) ||
             (userDoc.exists && userDoc.data.studentDocId == studentDocId);
    }

    // Bir submission'ın sahibi mi?
    function isSubmissionOwner(submissionId) {
      let sub = get(/databases/$(database)/documents/submissions/$(submissionId)).data;
      return isStudentOwner(sub.studentId);
    }

    // ─── students ─────────────────────────────────────────────────────────────

    match /students/{studentId} {
      allow read: if isInstructor()
                  || request.auth.uid == studentId
                  || (isSignedIn() && resource.data.authUid == request.auth.uid);
      allow create: if isAdmin() || isInstructor();
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin() || hasPermissionOverride('CLASS_MANAGE');

      // ── group_history subcollection ──────────────────────────────────────
      match /group_history/{entryId} {
        allow read: if isAdmin() || isInstructor();
        allow create: if isAdmin() || isInstructor();
        allow update, delete: if isAdmin();
      }
    }

    // ─── student_snapshots ────────────────────────────────────────────────────

    match /student_snapshots/{snapshotId} {
      allow read: if isAdmin() || isInstructor();
      allow create, update: if isAdmin() || isInstructor();
      allow delete: if isAdmin();
    }

    // ─── groups ───────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() || hasPermissionOverride('CLASS_MANAGE') ||
        (isInstructor() && resource.data.instructorId == currentUid());
      allow create, delete: if isAdmin() || hasPermissionOverride('CLASS_MANAGE');
    }

    // ─── users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && (currentUid() == userId || isAdmin() || isInstructor());
      allow update: if isSignedIn() && (currentUid() == userId || isAdmin());
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();

      // ─── users/{userId}/notifications ──────────────────────────────────────
      match /notifications/{notificationId} {
        // Only the owner reads their own notifications
        allow read: if request.auth.uid == userId;

        // Instructors/admins write (fan-out: sendAnnouncement + dispatch)
        // groupId opsiyonel — grup bildirimi, rol bildirimi veya sistem bildirimi olabilir
        allow create: if request.auth != null &&
                         (isAdmin() || request.auth.token.role in ['admin', 'instructor', 'teacher']) &&
                         request.resource.data.entityId is string &&
                         request.resource.data.senderId == request.auth.uid &&
                         request.resource.data.title is string &&
                         request.resource.data.preview is string &&
                         request.resource.data.actionUrl is string &&
                         request.resource.data.type in ['announcement', 'message', 'assignment', 'system'] &&
                         request.resource.data.preview.size() <= 100 &&
                         request.resource.data.title.size() <= 200;

        // Owner can only update read/archive state — affectedKeys guarantee immutability of all other fields
        allow update: if request.auth.uid == userId &&
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['isRead', 'readAt', 'isArchived', 'archivedAt']);

        allow delete: if false;
      }
    }

    // ─── memberships ─────────────────────────────────────────────────────────
    //
    // Okuma: sadece kendi kaydı (öğrenci kendi grup üyeliğini görebilir)
    // Yazma: Admin SDK üzerinden backend halleder

    match /memberships/{membershipId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.userId == currentUid()
      );
      allow create, update, delete: if false;
    }

    // ─── codes ───────────────────────────────────────────────────────────────
    //
    // Aktivasyon kodları — yalnızca Admin SDK (server-side) erişir.
    // Client-side erişim her işlemde kapalıdır.

    match /codes/{codeId} {
      allow read, write: if false;
    }

    // ─── tasks ────────────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── tasks/{taskId}/comments (sınıf yorumları) ────────────────────────────

    match /tasks/{taskId}/comments/{commentId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == currentUid();
      allow update: if isInstructor() || resource.data.authorId == currentUid();
      allow delete: if isInstructor() || resource.data.authorId == currentUid();
    }

    // ─── tasks/{taskId}/threads/{studentId}/comments (öğrenci-eğitmen özel) ───
    // Submission bağımsız stabil private thread

    match /tasks/{taskId}/threads/{studentId}/comments/{commentId} {
      // Read: isStudentOwner + token role fallback (authUid eksik öğrenciler için)
      allow read:   if isSignedIn() && (isInstructor() || isStudentOwner(studentId) || request.auth.token.role == 'student');
      // Create: sadece backend (Admin SDK) yazar — client write kapalı
      allow create: if false;
      // Update/delete: kendi yorumunu düzenleyebilir/silebilir
      allow update: if isSignedIn() && (isInstructor() || resource.data.authorId == currentUid());
      allow delete: if isSignedIn() && (isInstructor() || resource.data.authorId == currentUid());
    }

    // ─── templates ────────────────────────────────────────────────────────────

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── settings ─────────────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── scores_backup ────────────────────────────────────────────────────────

    match /scores_backup/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    match /scores_backup_entries/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── activity_log ─────────────────────────────────────────────────────────

    match /activity_log/{logId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ─── scoreLogs ────────────────────────────────────────────────────────────

    match /scoreLogs/{logId} {
      allow read: if isAdmin() || isInstructor();
      allow create: if isAdmin() || isInstructor();
      allow update, delete: if isAdmin();
    }

    // ─── lottery_configs ──────────────────────────────────────────────────────

    match /lottery_configs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── lottery_results ──────────────────────────────────────────────────────

    match /lottery_results/{taskId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow write: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── assignment_archive ───────────────────────────────────────────────────

    match /assignment_archive/{entryId} {
      allow read:   if isSignedIn() && (isAdmin() || isInstructor());
      allow create: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
      allow update: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
      allow delete: if isAdmin();
    }

    // ─── projectGrades ────────────────────────────────────────────────────────

    match /projectGrades/{gradeId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow write: if isAdmin() || isInstructor();
    }

    // ─── submissions ──────────────────────────────────────────────────────────

    match /submissions/{submissionId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.studentId == currentUid() ||
        get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.authUid == currentUid() ||
        get(/databases/$(database)/documents/users/$(currentUid())).data.get('studentDocId', '') == resource.data.studentId
      );
      allow update: if isInstructor() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'grade', 'feedback', 'gradedBy', 'reviewedAt', 'gradedAt', 'updatedAt']);
      allow delete: if isAdmin();
      allow create: if false;
    }

    // ─── submissions/{submissionId}/comments (özel yorumlar) ─────────────────

    match /submissions/{submissionId}/comments/{commentId} {
      allow read:   if isSignedIn() && (isInstructor() || isSubmissionOwner(submissionId));
      allow create: if isSignedIn() && (
        isInstructor() ||
        request.resource.data.authorId == currentUid()
      );
      allow delete: if isInstructor();
    }

    // ─── submission_comments ──────────────────────────────────────────────────

    match /submission_comments/{commentId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.authorId == currentUid()
      );
      allow create: if isSignedIn() && (
        isInstructor() ||
        (request.resource.data.authorId == currentUid() &&
         request.resource.data.authorType == "student")
      );
      allow update: if isInstructor() ||
        (resource.data.authorId == currentUid() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]));
      allow delete: if isInstructor();
    }

    // ─── submission_timeline ──────────────────────────────────────────────────

    match /submission_timeline/{entryId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        isStudentOwner(resource.data.studentId)
      );
      allow create, update, delete: if false;
    }

    // ─── submission_files ─────────────────────────────────────────────────────

    match /submission_files/{fileId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        isStudentOwner(resource.data.studentId)
      );
      allow create, update, delete: if false;
    }

    // ─── announcements ────────────────────────────────────────────────────────

    match /announcements/{announcementId} {
      allow create: if isAdmin() || isInstructor();

      allow read: if isSignedIn();

      allow update, delete: if request.auth.uid == resource.data.createdBy &&
                               (isAdmin() || isInstructor());
    }

    // ─── system_backups ───────────────────────────────────────────────────────

    match /system_backups/{backupId} {
      allow read, write: if isAdmin();
    }

    match /system_backups/{backupId}/{col}/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── categories ──────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ─── branches ────────────────────────────────────────────────────────────

    match /branches/{branchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /branches/{branchId}/modules/{moduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ─── sessions (seans şablonları) ─────────────────────────────────────────

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ─── attendance ───────────────────────────────────────────────────────────

    match /design_attendance/{docId} {
      allow read: if isInstructor();
      allow create, update: if isInstructor();
      allow delete: if isAdmin();
    }

    match /attendance/{docId} {
      allow read: if isInstructor();
      allow create, update: if isInstructor();
      allow delete: if isAdmin();
    }

    match /lesson_exceptions/{docId} {
      allow read: if isInstructor();
      allow create, update: if isInstructor();
      allow delete: if isAdmin();
    }

    // ─── holidays (tatil takvimi) ─────────────────────────────────────────────

    match /holidays/{holidayId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ─── chats (FlexOS: öğrenci↔eğitmen ANLIK 1:1 sohbet) ────────────────────
    //
    // 2026-07-13 kararı: `flexos_comments`'teki 1:1 thread için önce in-memory
    // SSE broadcast denendi, CANLI TESTTE Turbopack dev'de route'lar arası modül
    // paylaşmadığı kanıtlandı (bkz. realtime-hub.ts yorumu) — polling'e (6sn)
    // düşüldü ama canlı sistemdeki gerçek anlıklığın kaynağı zaten Firestore
    // `onSnapshot` idi. Bu koleksiyon AYNI deseni (`tasks/{id}/threads/{studentId}/
    // comments` ile birebir) yeni mimariye taşır: SADECE bu chat'in hoca/öğrenci
    // uid'i eşleşen kullanıcı OKUYABİLİR (onSnapshot), YAZMA HER ZAMAN Admin SDK
    // (comment-service.ts) üzerinden — mevcut yetki/kayıt/durum kontrolleri
    // rules'a taşınmadı, "tek kapı" (API) yazma tarafında korunuyor.

    match /chats/{chatId} {
      allow read: if isSignedIn() &&
        (request.auth.uid == resource.data.trainerUid || request.auth.uid == resource.data.studentUid);
      allow write: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          (request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.trainerUid ||
           request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.studentUid);
        allow write: if false;
      }
    }

    // ─── FlexOS yeniden-inşa (yeni koleksiyonlar) ─────────────────────────────
    //
    // persons / enrollments: TÜM erişim Admin SDK (server) üzerinden, gated
    // service'ten geçer (yetki + PII filtreleme orada). Client erişimi kapalı —
    // PII'ı korumak ve "tek kapı" disiplinini zorlamak için. Daha ince client
    // okuma kuralları, capability token'a girince eklenecek (FLEXOS.md §3).

    match /persons/{personId} {
      allow read, write: if false;
    }

    match /enrollments/{enrollmentId} {
      allow read, write: if false;
    }

    // Yeni grup modeli — canlı `groups` KULLANIMDA, çakışmasın diye ayrı koleksiyon.
    match /flexos_groups/{groupId} {
      allow read, write: if false;
    }

    // Katalog (Branş/Eğitim/Bölüm/Track) — canlı `branches` çakışmasın diye flexos_ önekli.
    match /flexos_branches/{id} { allow read, write: if false; }
    match /flexos_branch_offices/{id} { allow read, write: if false; }
    match /flexos_educations/{id} { allow read, write: if false; }
    match /flexos_sections/{id} { allow read, write: if false; }
    match /flexos_tracks/{id} { allow read, write: if false; }

    // CRM pipeline — satış öncesi adaylar. Sadece admin ve sales rolü erişir.
    match /flexos_prospects/{id} {
      allow read, write: if isAdmin() ||
        (isSignedIn() && (
          request.auth.token.role in ['admin', 'sales'] ||
          getUserData().get('roles', []).hasAny(['admin', 'sales'])
        ));
    }

    // Satış kayıtları — server-only (Admin SDK), PII + finansal veri koruması.
    match /flexos_sales/{id} { allow read, write: if false; }

    // Tahsilat/taksit kayıtları — server-only (Admin SDK), finansal veri koruması.
    match /flexos_payments/{id} { allow read, write: if false; }

    // Eğitmen kadrosu — server-only (Admin SDK), ücret (hourlyRate) koruması gated service'te.
    match /flexos_trainers/{id} { allow read, write: if false; }

    // Seans kalıpları — server-only.
    match /flexos_seanslar/{id} { allow read, write: if false; }

    // Yoklama kayıtları — server-only (Admin SDK). Görünürlük (eğitmen kendi grubu
    // 3 gün / Op+Finans rapor tüm gruplar) gated service'te (attendance-service.ts).
    match /flexos_attendance/{id} { allow read, write: if false; }

    // Eğitmen günlük iş logu (Ana Sayfa "En Son Aktiviteler") — server-only (Admin SDK).
    // CRM "Aktivite Merkezi" (flexos_activities) ile KARIŞTIRILMASIN, ayrı koleksiyon.
    match /flexos_activity_log/{id} { allow read, write: if false; }

    // Senelik tatiller — server-only (Admin SDK), yazma `holiday.manage` gated (Op+Admin).
    match /flexos_holidays/{id} { allow read, write: if false; }

    // Ders istisnaları ("Ders Olmadı") — server-only (Admin SDK), gated attendance-service'te.
    match /flexos_lesson_exceptions/{id} { allow read, write: if false; }

    // Sistem anahtarları (standaloneMode switch vb.) — server-only.
    match /flexos_settings/{id} { allow read, write: if false; }

    // Admin Kişisel Görünüm Anahtarı PIN'i (Core/Full) — server-only, hash'li.
    match /flexos_view_pins/{uid} { allow read, write: if false; }

    // Admin Kişisel Görünüm Anahtarı — mevcut mod (Core/Full), server-only.
    match /flexos_view_modes/{uid} { allow read, write: if false; }

    // Sertifika/ödev notları — server-only (Admin SDK), gated grade-service.ts (grade.read/write).
    match /flexos_grades/{id} { allow read, write: if false; }

    // Sertifika hesaplama ayarı (odevAktif/sertifikaPct) — server-only, yazma `certificate.settings.write` gated.
    match /flexos_certificate_settings/{id} { allow read, write: if false; }

    // Kullanıcı/rol yönetimi (Kullanıcılar + Kullanıcı Ayarları) — server-only (Admin SDK).
    match /flexos_users/{id} { allow read, write: if false; }
    match /flexos_role_defs/{id} { allow read, write: if false; }
    // Aktivasyon kodları — server-only; public `activation/verify` route'u bile Admin SDK üzerinden okur.
    match /flexos_codes/{id} { allow read, write: if false; }

    // ─── connect_conversations (Flex Connect — BAĞIMSIZ kurumsal mesajlaşma) ──
    //
    // Ödev/teslim `chats` koleksiyonuna HİÇ dokunmaz, tamamen ayrı. Tüm yazma
    // Admin SDK (connect-service.ts) üzerinden — `chats`'teki AYNI "tek kapı"
    // deseni. Sadece OKUMA açık (`onSnapshot` gerçek-zamanlılık için).
    //
    // İzolasyonun bel kemiği: öğrenci `realm:"staff"` bir konuşmayı HİÇBİR
    // koşulda okuyamaz — ne üye olarak (öğrenci staff'a asla eklenmez, servis
    // reddeder) ne audience köprüsüyle (audience SADECE realm:"trainer_student"
    // konuşmalarda anlamlı, aşağıdaki kural bunu AÇIKÇA zorunlu kılar).
    function isConnectMember(conversationId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/connect_conversations/$(conversationId)/members/$(request.auth.uid));
    }

    function isConnectAudienceOpen(conversationId) {
      let conv = get(/databases/$(database)/documents/connect_conversations/$(conversationId)).data;
      return conv.realm == "trainer_student" && conv.audience == "all_students";
    }

    match /connect_conversations/{conversationId} {
      allow read: if isConnectMember(conversationId) ||
        (resource.data.realm == "trainer_student" && resource.data.audience == "all_students");
      allow write: if false;

      // Üyelik + okunma + tercih (2026-07-18 revizyonu: memberUids[] ve ayrı
      // `reads` koleksiyonu YOK — hepsi burada). Kendi dokümanını (lastReadAt/
      // muted/pinned) + konuşmanın diğer üyelerini (roster/"428 üye") okur.
      match /members/{uid} {
        allow read: if isSignedIn() && (uid == request.auth.uid || isConnectMember(conversationId));
        allow write: if false;
      }

      match /messages/{messageId} {
        allow read: if isConnectMember(conversationId) || isConnectAudienceOpen(conversationId);
        allow write: if false;
      }

      // "Yazıyor" presence sinyali (2026-07-18) — mesajlarla AYNI okuma kapısı,
      // yazma SADECE Admin SDK (connect-service.ts::setTypingSignal).
      match /typing/{uid} {
        allow read: if isConnectMember(conversationId) || isConnectAudienceOpen(conversationId);
        allow write: if false;
      }
    }

    // Flex Connect — Presence (2026-07-20). "Yazıyor" sinyalinden FARKLI:
    // konuşmaya özel DEĞİL, personel başına TEK global doküman. Personel
    // dizini/öğrenci tarafı gibi ortak konuşması olmayan biri için de
    // görünmesi gerektiğinden okuma tenant-genelinde herhangi bir giriş
    // yapmış kullanıcıya açık. Yazma yine SADECE Admin SDK
    // (connect-presence-service.ts).
    match /connect_presence/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Connect Audit Log — kullanıcı hareketi DEĞİL, yönetimsel işlem kaydı
    // (kanal/grup/topluluk oluşturma, üye ekle/çıkar, vb.). Server-only,
    // `flexos_activity_log`'daki AYNI desen: client hiçbir zaman okuyamaz/yazamaz,
    // gelecekteki yönetim paneli bir API route üzerinden (Admin SDK) okur.
    match /connect_audit/{id} { allow read, write: if false; }
  }
}
