rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Schema validation: zorunlu user field'larını kontrol eder
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'name', 'surname', 'roles']) &&
             data.email is string &&
             data.name is string &&
             data.surname is string &&
             data.roles is list;
    }

    function currentUid() {
      return request.auth.uid;
    }

    // Gizli sistem sahibi — Firestore'a bakmadan tam yetki
    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'flexos.platform@gmail.com';
    }

    // Firestore dokümanındaki rollere bak (diğer kullanıcılar için)
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(currentUid())).data;
    }

    function isAdmin() {
      return isSuperAdmin() ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['admin'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'admin');
    }

    function isInstructor() {
      return isAdmin() ||
        (isSignedIn() && getUserData().get('roles', []).hasAny(['instructor'])) ||
        (isSignedIn() && getUserData().get('role', '') == 'instructor');
    }

    function hasPermissionOverride(perm) {
      return isSignedIn() && getUserData().get('permissionOverrides', {}).get(perm, false) == true;
    }

    // ─── students ─────────────────────────────────────────────────────────────

    match /students/{studentId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow create: if isAdmin() || isInstructor();
      allow update: if isAdmin() || isInstructor();
      allow delete: if isAdmin() || hasPermissionOverride('CLASS_MANAGE');
    }

    // ─── groups ───────────────────────────────────────────────────────────────

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow update: if isAdmin() || hasPermissionOverride('CLASS_MANAGE') ||
        (isInstructor() && resource.data.instructorId == currentUid());
      allow create, delete: if isAdmin() || hasPermissionOverride('CLASS_MANAGE');
    }

    // ─── users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor() || currentUid() == userId);
      allow update: if isSignedIn() && (isAdmin() || currentUid() == userId);
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    // ─── tasks ────────────────────────────────────────────────────────────────

    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── templates ────────────────────────────────────────────────────────────

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isInstructor();
    }

    // ─── settings ─────────────────────────────────────────────────────────────

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── scores_backup ────────────────────────────────────────────────────────

    match /scores_backup/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    match /scores_backup_entries/{docId} {
      allow read: if isAdmin() || isInstructor();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── scoreLogs ────────────────────────────────────────────────────────────

    match /scoreLogs/{logId} {
      allow read: if isAdmin() || isInstructor();
      allow create: if isAdmin() || isInstructor();
      allow update, delete: if isAdmin();
    }

    // ─── lottery_configs ──────────────────────────────────────────────────────

    match /lottery_configs/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── lottery_results ──────────────────────────────────────────────────────

    match /lottery_results/{taskId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow write: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
    }

    // ─── assignment_archive ───────────────────────────────────────────────────

    match /assignment_archive/{entryId} {
      allow read:   if isSignedIn() && (isAdmin() || isInstructor());
      allow create: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
      allow update: if isAdmin() || isInstructor() || hasPermissionOverride('ASSIGNMENT_MANAGE');
      allow delete: if isAdmin();
    }

    // ─── projectGrades ────────────────────────────────────────────────────────

    match /projectGrades/{gradeId} {
      allow read: if isSignedIn() && (isAdmin() || isInstructor());
      allow write: if isAdmin() || isInstructor();
    }

    // ─── submissions ──────────────────────────────────────────────────────────
    //
    // Öğrenci → kendi submission'ını okuyabilir (student portal için)
    // Öğretmen/Admin → tüm submission'ları okuyabilir, status güncelleyebilir
    // Create → sadece server-side API route (Admin SDK) — client kuralı yok
    //
    // NOT: createSubmission işlemi Admin SDK ile yapıldığı için bu kurala takılmaz.
    // Buradaki kurallar client-side (student portal) erişim içindir.

    match /submissions/{submissionId} {
      // Öğrenci kendi kaydını okuyabilir
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.studentId == currentUid()
      );

      // Sadece instructor/admin status ve not güncelleyebilir
      allow update: if isInstructor() &&
        // Sadece izin verilen alanları güncelleyebilir
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'grade', 'feedback', 'gradedBy', 'reviewedAt', 'gradedAt', 'updatedAt']);

      // Silme sadece admin
      allow delete: if isAdmin();

      // Create: client-side create yok — API route (Admin SDK) halleder
      allow create: if false;
    }

    // ─── submission_comments ──────────────────────────────────────────────────
    //
    // Teacher/Admin → tüm comment'leri okur, oluşturur, siler
    // Student       → sadece kendi submission'ına ait comment'leri okur ve oluşturur
    // Create → server-side (Admin SDK) veya isRead/order kontrolü ile client

    match /submission_comments/{commentId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.authorId == currentUid()
      );
      allow create: if isSignedIn() && (
        isInstructor() ||
        // Öğrenci kendi adına yorum yapabilir
        (request.resource.data.authorId == currentUid() &&
         request.resource.data.authorType == "student")
      );
      allow update: if isInstructor() ||
        // Öğrenci sadece kendi yorumunu isRead=true yapabilir
        (resource.data.authorId == currentUid() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]));
      allow delete: if isInstructor();
    }

    // ─── submission_timeline ──────────────────────────────────────────────────
    //
    // Sadece server-side yazılır (Admin SDK).
    // Öğrenci → kendi kayıtlarını okuyabilir.
    // Teacher → tüm kayıtları okuyabilir.

    match /submission_timeline/{entryId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.studentId == currentUid()
      );
      // Create/update/delete → yalnızca Admin SDK (server-side); client'tan kapalı
      allow create, update, delete: if false;
    }

    // ─── submission_files ─────────────────────────────────────────────────────
    //
    // Teacher → tüm dosyaları okur
    // Student → kendi submission'ına ait dosyaları okur
    // Write   → yalnızca server-side (Admin SDK)

    match /submission_files/{fileId} {
      allow read: if isSignedIn() && (
        isInstructor() ||
        resource.data.studentId == currentUid()
      );
      allow create, update, delete: if false;
    }

    // ─── system_backups ───────────────────────────────────────────────────────

    match /system_backups/{backupId} {
      allow read, write: if isAdmin();
    }

    match /system_backups/{backupId}/{col}/{docId} {
      allow read, write: if isAdmin();
    }
  }
}
